# ==============================================================================
# ARC Explainer — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in values for the features you need.
# Only DATABASE_URL + at least one AI provider key are required to start.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------

# PostgreSQL connection string (required for persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/arc_explainer

# Test database (only needed for running tests)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/arc_explainer_test

# ------------------------------------------------------------------------------
# SERVER CONFIG
# ------------------------------------------------------------------------------

# HTTP port (default: 5000)
PORT=3000

# Runtime environment: development | production | test
# NODE_ENV=development

# Public base URL for meta tags / OpenGraph previews
# BASE_URL=https://arc.markbarney.net

# Logging level: debug | info | warn | error
# LOG_LEVEL=info

# Path to Python 3 binary (auto-detected if not set)
# Used by Saturn solver, RE-ARC generator, SnakeBench, Poetiq, ARC3 game bridges
# PYTHON_BIN=/usr/bin/python3

# ------------------------------------------------------------------------------
# AI PROVIDER API KEYS — Core Application
# At least one provider key is required for puzzle analysis & ARC3 gameplay
# ------------------------------------------------------------------------------

# OpenAI (GPT-4.1, GPT-5, GPT-5.1, o3, o4-mini, Codex)
# Used for: puzzle analysis, ARC3 agent, model debate, explanations
OPENAI_API_KEY=sk-proj-...

# Anthropic (Claude Opus 4.5, Claude Sonnet, Claude Haiku)
# Used for: puzzle analysis, model debate, council voting
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (Gemini 2.5 Pro/Flash, Gemini 3 Flash Preview)
# Used for: puzzle analysis, model debate
# GEMINI_API_KEY=AI...

# xAI Grok (Grok-4, Grok-3)
# Used for: puzzle analysis, model debate
# GROK_API_KEY=xai-...

# DeepSeek (DeepSeek-R1, DeepSeek-V3)
# DEEPSEEK_API_KEY=sk-...

# OpenRouter (multi-model proxy — access 200+ models via single key)
# Required for: LLM Council, Poetiq solver, Kimi K2.5 access
# OPENROUTER_API_KEY=sk-or-v1-...

# Custom OpenRouter referer header (optional)
# OPENROUTER_REFERER=https://your-site.com

# xAI direct API key (used by SnakeBench and Poetiq provider mapping)
# XAI_API_KEY=xai-...

# ARC3 platform API key (required for ARC3 playground remote game access)
# Obtained from https://three.arcprize.org
# ARC3_API_KEY=arc3-...

# ------------------------------------------------------------------------------
# AI PROVIDER API KEYS — Eval Harness
# These are only needed if you run the eval harness (/eval dashboard)
#
# IMPORTANT: The eval orchestrator validates that every selected model has
# its required env var set BEFORE starting. If a key is missing, the eval
# will fail immediately with a clear error message.
#
# Model -> Required Key mapping:
#   gemini-3.1              -> GEMINI_STUDIO_API_KEY
#   gemini-3.1-studio       -> GEMINI_STUDIO_API_KEY
#   gemini-3.1-standard     -> GEMINI_API_KEY
#   gemini-3.1-priority     -> GEMINI_API_KEY
#   gemini-3.1-openrouter   -> OPENROUTER_API_KEY
#   gpt-5.4-thinking        -> GPT_API_KEY
#   claude-bedrock           -> BEDROCK_API_KEY
#   kimi-bedrock             -> BEDROCK_API_KEY
#   claude-a1 through a6    -> ANTHROPIC_API_KEY_1 through _6
#   litellm-*               -> LITELLM_MASTER_KEY + LITELLM_PROXY_URL
# ------------------------------------------------------------------------------

# GPT-5.4 thinking model (eval harness specific key)
# GPT_API_KEY=sk-proj-...

# Google Gemini Studio tier key (separate from GEMINI_API_KEY for rate limits)
# GEMINI_STUDIO_API_KEY=AI...

# Google API key (Gemini provider fallback)
# GOOGLE_API_KEY=AI...

# AWS Bedrock (Claude Opus 4.6 + Kimi K2.5 via Bedrock)
# BEDROCK_API_KEY=...
# AWS_REGION=us-east-1

# Bedrock custom model ARNs (cross-account inference profiles)
# BEDROCK_CLAUDE_ARN=arn:aws:bedrock:us-east-1:123456789:inference-profile/...
# BEDROCK_CLAUDE_ARN_2=arn:aws:bedrock:us-east-1:123456789:inference-profile/...
# BEDROCK_KIMI_ARN=arn:aws:bedrock:us-east-1:123456789:inference-profile/...

# Anthropic multi-account keys (eval harness rotates across accounts for rate limits)
# ANTHROPIC_API_KEY_1=sk-ant-...
# ANTHROPIC_API_KEY_2=sk-ant-...
# ANTHROPIC_API_KEY_3=sk-ant-...
# ANTHROPIC_API_KEY_4=sk-ant-...
# ANTHROPIC_API_KEY_5=sk-ant-...
# ANTHROPIC_API_KEY_6=sk-ant-...

# Moonshot Kimi K2.5 (native API, alternative to Bedrock/OpenRouter)
# MOONSHOT_API_KEY=sk-...

# LiteLLM proxy (universal provider gateway)
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_MASTER_KEY=sk-...

# ------------------------------------------------------------------------------
# ARC3 GAME CONFIG
# ------------------------------------------------------------------------------

# Override default Codex model for ARC3 Codex playground
# CODEX_ARC_MODEL=gpt-5.1-codex-mini

# Admin token for ARC3 community game upload/management endpoints
# ARC3_COMMUNITY_ADMIN_TOKEN=your-secret-token

# ------------------------------------------------------------------------------
# RE-ARC BENCHMARK
# ------------------------------------------------------------------------------

# Server secret for RE-ARC dataset generation (32+ character random string)
# Used to derive internal seeds that prevent dataset regeneration without server access
RE_ARC_SEED_PEPPER=your-secret-pepper-here-minimum-32-characters-required

# Enable RE-ARC dev mode (skips security checks, exposes test outputs)
# RE_ARC_DEV_MODE=true
# RE_ARC_TEST_EXPOSE_OUTPUTS=true

# ------------------------------------------------------------------------------
# SNAKEBENCH / WORM ARENA
# ------------------------------------------------------------------------------

# GitHub integration for replay publishing
# SNAKEBENCH_GITHUB_TOKEN=ghp_...
# SNAKEBENCH_GITHUB_OWNER=VoynichLabs
# SNAKEBENCH_GITHUB_REPO=SnakeBench
# SNAKEBENCH_GITHUB_BRANCH=main
# SNAKEBENCH_GITHUB_REPLAY_DIR=replays

# Match execution config
# SNAKEBENCH_TIMEOUT_MS=300000
# SNAKEBENCH_INGEST_MAX_RETRIES=5
# SNAKEBENCH_INGEST_RETRY_DELAY_MS=5000

# Upstream SnakeBench API and replay URL
# SNAKEBENCH_UPSTREAM_BACKEND_URL=https://snakebench-api.example.com
# SNAKEBENCH_REPLAY_RAW_BASE=https://raw.githubusercontent.com/VoynichLabs/SnakeBench/main

# ------------------------------------------------------------------------------
# SATURN / GROVER / POETIQ SOLVERS
# ------------------------------------------------------------------------------

# Saturn visual solver timeout in minutes (default: 10)
# SATURN_TIMEOUT_MINUTES=10

# LLM Council timeout in milliseconds (default: 180000 = 3 minutes)
COUNCIL_TIMEOUT_MS=180000

# LLM Council service base URL (default: http://localhost:8001)
# COUNCIL_BASE_URL=http://localhost:8001

# ------------------------------------------------------------------------------
# xAI RETRY CONFIG
# ------------------------------------------------------------------------------

# XAI_MAX_RETRIES=3
# XAI_RETRY_BASE_DELAY_MS=1000

# ------------------------------------------------------------------------------
# AUTH / SECURITY
# ------------------------------------------------------------------------------

# Admin secret for protected admin endpoints (X-Admin-Secret header)
# Required for: model management mutations, ingestion, recovery, admin dashboard
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Master API key for authenticated endpoints
# ARC_EXPLAINER_API_KEY=your-master-key

# Comma-separated list of valid public API keys
# PUBLIC_API_KEYS=key1,key2,key3

# HuggingFace token for dataset ingestion scripts
# HF_TOKEN=hf_...

# ------------------------------------------------------------------------------
# STREAMING / FEATURE FLAGS
# ------------------------------------------------------------------------------

# Master streaming toggle (enables SSE for all streaming features)
# STREAMING_ENABLED=true
# ENABLE_SSE_STREAMING=true

# Frontend streaming (Vite injects these at build time)
# VITE_STREAMING_ENABLED=true
# VITE_ENABLE_SSE_STREAMING=true

# Frontend API URL override (default: same origin)
# VITE_API_URL=http://localhost:3000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_STUDIO_API_KEY=
GOOGLE_API_KEY=
GPT_API_KEY=
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=
BEDROCK_API_KEY=
AWS_REGION=us-east-1
BEDROCK_CLAUDE_ARN=
BEDROCK_KIMI_ARN=
GROK_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY_1=
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
ANTHROPIC_API_KEY_4=
ANTHROPIC_API_KEY_5=
ANTHROPIC_API_KEY_6=
LITELLM_PROXY_URL=
LITELLM_MASTER_KEY=
ARC3_API_KEY=
PORT=3000
NODE_ENV=development
RE_ARC_SEED_PEPPER=
COUNCIL_TIMEOUT_MS=180000
OPENROUTER_REFERER=
ARC3_COMMUNITY_ADMIN_TOKEN=
STREAMING_ENABLED=true
ENABLE_SSE_STREAMING=true
